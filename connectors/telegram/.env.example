# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Copilot Bridge server URL (VS Code extension must be running)
BRIDGE_URL=http://127.0.0.1:7842

# API key (must match the one set in VS Code settings)
BRIDGE_API_KEY=

# Optional: Restrict bot to specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
ALLOWED_USERS=
